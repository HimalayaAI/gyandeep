# Sarvam AI API key (required)
SARVAMAI_KEY=your_key_here

# Tesseract OCR binary path (optional, defaults to Windows standard path)
# TESSERACT_PATH=/usr/bin/tesseract

# Max completion tokens for Sarvam API (optional, default 16384)
# Reasoning models need high limits to avoid truncation
# SARVAM_MAX_TOKENS=16384

# Server settings (optional)
# SERVER_HOST=0.0.0.0
# SERVER_PORT=8000

# Logging level (optional, defaults to INFO)
# LOG_LEVEL=INFO
